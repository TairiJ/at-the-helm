# ⚓ AT THE HELM - Server Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Auth & Security
JWT_SECRET=your_jwt_secret_here
# Resonance Key (Default)
DEFAULT_RESONANCE_KEY=1234

# LLM Providers (Add your keys below)
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_GENAI_API_KEY=your_google_key
OPENAI_API_KEY=your_openai_key

# Database (Default is ../../data/helm.db)
# DATA_DIR=../../data
