{
  "name": "at-the-helm",
  "version": "1.0.0",
  "private": true,
  "description": "At The Helm — AI Operator Cockpit",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "guardian:build": "cd guardian && cargo build --release",
    "guardian:build:dev": "cd guardian && cargo build",
    "guardian:run": "guardian\\target\\release\\helm-guardian.exe"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^9.1.2"
  }
}
